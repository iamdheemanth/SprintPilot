# SprintPilot defaults to a pinned OpenRouter free model with explicit free-model fallbacks.
SPRINTPILOT_MODEL_PROVIDER=openrouter
SPRINTPILOT_MODEL_NAME=openai/gpt-oss-20b:free
SPRINTPILOT_FALLBACK_MODELS=nvidia/nemotron-nano-9b-v2:free,qwen/qwen3-next-80b-a3b-instruct:free,google/gemma-4-31b-it:free
SPRINTPILOT_MODEL_MAX_RETRIES=2
SPRINTPILOT_MODEL_TIMEOUT_SECONDS=120

# Set one of these locally. Never commit real API keys.
OPENROUTER_API_KEY=
# SPRINTPILOT_OPENROUTER_API_KEY=

# To use Gemini instead:
# SPRINTPILOT_MODEL_PROVIDER=gemini
# SPRINTPILOT_MODEL_NAME=gemini-2.5-flash
# GEMINI_API_KEY=
# SPRINTPILOT_GEMINI_API_KEY=
